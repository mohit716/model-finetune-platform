# ── Database ─────────────────────────────────────────
# For local dev (SQLite):
DATABASE_URL=sqlite:///./data/finetune.db
# For Docker Compose (PostgreSQL):
# DATABASE_URL=postgresql://finetune:finetune@localhost:5432/finetune

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Storage ──────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_PATH=./data

# MinIO (uncomment for S3-compatible storage)
# STORAGE_BACKEND=minio
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# ── HuggingFace ─────────────────────────────────────
# Required for gated models (Llama, Mistral, etc.)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HF_CACHE_DIR=./data/hf_cache

# ── Inference ────────────────────────────────────────
INFERENCE_BACKEND=transformers
# INFERENCE_BACKEND=vllm
